    },
    {
      "parameters": {
        "jsCode": "const BASE_PARTICIPANTS = 6000;\nconst MANUAL_PROVINCES = 2;\nconst MANUAL_CITIES = 4;\n\nconst rows = $input.all();\nconst formCount = rows.length;\n\nreturn [{\n  json: {\n    cache_key: 'latest',\n    participants: BASE_PARTICIPANTS + formCount,\n    registrations_from_form: formCount,\n    base_participants: BASE_PARTICIPANTS,\n    provinces: MANUAL_PROVINCES,\n    cities: MANUAL_CITIES,\n    goalFirst: 50000,\n    goalSecond: 500000,\n    goalMain: 1000000,\n    freeRatio: 10,\n    updated_at: new Date().toISOString()\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [780, 390],
      "id": "stats-calc-004",
      "name": "Calculate Stats"
    },
