      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1.1,
      "position": [520, 120],
      "id": "stats-load-cache-009",
      "name": "Get Stats Cache"
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.all();\n\nconst DEFAULT_STATS = {\n  participants: 6000,\n  base_participants: 6000,\n  registrations_from_form: 0,\n  provinces: 2,\n  cities: 4,\n  goalFirst: 50000,\n  goalSecond: 500000,\n  goalMain: 1000000,\n  freeRatio: 10,\n  updated_at: null\n};\n\nif (!rows.length) {\n  return [{ json: DEFAULT_STATS }];\n}\n\nconst r = rows[0].json;\nconst num = (v, fallback) => {\n  const n = Number(v);\n  return Number.isFinite(n) ? n : fallback;\n};\n\nreturn [{\n  json: {\n    participants: num(r.participants, DEFAULT_STATS.participants),\n    registrations_from_form: num(r.registrations_from_form, 0),\n    base_participants: num(r.base_participants, 6000),\n    provinces: num(r.provinces, 2),\n    cities: num(r.cities, 4),\n    goalFirst: num(r.goalFirst, 50000),\n    goalSecond: num(r.goalSecond, 500000),\n    goalMain: num(r.goalMain, 1000000),\n    freeRatio: num(r.freeRatio, 10),\n    updated_at: r.updated_at || null\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [780, 120],
      "id": "stats-format-010",
      "name": "Format Stats Response"
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify($json) }}",
        "options": {
